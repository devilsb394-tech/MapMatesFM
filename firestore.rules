// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: Firebase Auth UID
// Fields:
//   - uid: string (required) - The user's unique ID
//   - username: string (required, 1-50 chars) - Display name
//   - email: string (required) - User's email
//   - photoURL: string (required) - Profile picture URL
//   - bio: string (required) - User biography
//   - gender: string (required) - User gender
//   - religion: string (required) - User religion
//   - language: string (required) - Primary language
//   - age: number (required, >= 18) - User age
//   - relationshipStatus: string (required) - Relationship status
//   - profession: string (required) - User's job
//   - economicClass: string (required) - Economic background
//   - location: map (required) - { lat: number, lng: number, lastUpdated: string }
//   - isOnline: boolean (required) - Online status
//   - lastSeen: string (required) - ISO date string
//   - stats: map (required) - { views: number, likes: number, friendsCount: number }
//
// Collection: history
// Document ID: Auto-generated
// Fields:
//   - uid: string (required) - User who created the entry
//   - action: string (required) - Action performed
//   - details: string (required) - Description of the action
//   - timestamp: string (required) - ISO date string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "devilsb394@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.username is string && data.username.size() > 0 && data.username.size() < 100 &&
             data.email is string && data.email.size() > 0 &&
             data.uid == request.auth.uid;
    }

    function isValidNotification(data) {
      return data.uid is string && data.fromId is string &&
             data.type in ['message', 'friend_request', 'like'] &&
             data.read is bool && data.timestamp is string;
    }

    function isValidFriendRequest(data) {
      return data.from is string && data.to is string &&
             data.status in ['pending', 'accepted', 'rejected'] &&
             data.createdAt is string;
    }

    function isValidHistory(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.type in ['search', 'view'] &&
             data.timestamp is string;
    }

    function isValidSocialAction(data) {
      return data.fromId is string && data.fromId == request.auth.uid &&
             data.toId is string && data.type in ['view', 'like'] &&
             data.timestamp is string;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (
        isOwner(userId) || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats'])
      );
      allow delete: if isOwner(userId) || isAdmin();
      
      match /views/{viewId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == viewId && request.auth.uid != userId;
      }
      
      match /likes/{likeId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == likeId && request.auth.uid != userId;
        allow delete: if isAuthenticated() && request.auth.uid == likeId;
      }
      
      match /friends/{friendId} {
        allow read: if isAuthenticated();
        allow create, delete: if isOwner(userId) || isOwner(friendId) || isAdmin();
      }
    }

    match /socialActions/{actionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSocialAction(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.fromId == request.auth.uid;
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.fromId == request.auth.uid && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.from == request.auth.uid && isValidFriendRequest(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid) && isValidFriendRequest(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid || isAdmin());
    }

    match /conversations/{convId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId;
        allow delete: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }

    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.from;
    }

    match /history/{historyId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidHistory(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
